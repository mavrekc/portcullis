# Copy to .env and fill in real values. Never commit real secrets.

# LLM provider key, used only by tooling/tests that touch a model (e.g. classifier heuristics
# eval scripts, red-team harness). The proxy core itself does not require an LLM to run.
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# Address of the upstream MCP server(s) the proxy fronts, comma-separated.
PORTCULLIS_UPSTREAM_MCP_URLS=http://localhost:9001,http://localhost:9002

# Port the portcullis gateway listens on.
PORTCULLIS_LISTEN_PORT=8080

# Path to the versioned policy YAML file loaded at startup.
PORTCULLIS_POLICY_FILE=./policies/default.yaml

# Path/DSN for the append-only, hash-chained audit log store.
PORTCULLIS_AUDIT_LOG_DSN=sqlite:///./audit.db

# Admin plane shared secret (rotate regularly; used for capability overrides and re-approvals).
PORTCULLIS_ADMIN_TOKEN=changeme-admin-token
